{
  "name": "rsc-utils",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./functions/server": {
      "types": "./dist/plugins/functions/server.d.ts",
      "default": "./dist/plugins/functions/server.js"
    },
    "./functions/browser": {
      "types": "./dist/plugins/functions/browser.d.ts",
      "default": "./dist/plugins/functions/browser.js"
    },
    "./ssg": {
      "types": "./dist/plugins/ssg/ssg-entry.d.ts",
      "default": "./dist/plugins/ssg/ssg-entry.js"
    },
    "./ssr": {
      "types": "./dist/plugins/ssg/ssr-entry.d.ts",
      "default": "./dist/plugins/ssg/ssr-entry.js"
    },
    "./types": {
      "types": "./dist/ambient.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build && cp src/ambient.d.ts dist/ambient.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@vitejs/plugin-rsc": "~0.5.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "~0.5.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rsc-html-stream": "^0.0.7",
    "typescript": "~5.9.3",
    "vite": "^8.0.8"
  }
}
